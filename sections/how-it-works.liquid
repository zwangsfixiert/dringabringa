{% comment %} sections/how-it-works.liquid – DringaBringa v3 {% endcomment %}

<section class="how-it-works section-pad">
  <div class="container">
    <div class="how-header">
      <div class="section-eyebrow" style="color:var(--ice)">SO EINFACH GEHT'S</div>
      <div class="section-title">In 3 Schritten zu deiner Lieferung</div>
    </div>

    <div class="how-grid">

      <div class="how-card">
        <div class="how-num">01</div>
        <div class="how-icon">🛒</div>
        <h3 class="how-title">{{ section.settings.step1_title | default: 'Produkt wählen' }}</h3>
        <p class="how-desc">{{ section.settings.step1_desc | default: 'Stöbere durch unser Sortiment – von kühlem Bier bis Energy Drinks und Snacks.' }}</p>
      </div>

      <div class="how-card">
        <div class="how-num">02</div>
        <div class="how-icon">📦</div>
        <h3 class="how-title">{{ section.settings.step2_title | default: 'Bestellen' }}</h3>
        <p class="how-desc">{{ section.settings.step2_desc | default: 'Leg alles in den Warenkorb und schließe deine Bestellung in wenigen Sekunden ab.' }}</p>
      </div>

      <div class="how-card">
        <div class="how-num">03</div>
        <div class="how-icon">🚀</div>
        <h3 class="how-title">{{ section.settings.step3_title | default: 'In 25 Min geliefert' }}</h3>
        <p class="how-desc">{{ section.settings.step3_desc | default: 'Unser Fahrer bringt deine Bestellung frisch & gekühlt direkt vor deine Haustür.' }}</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wie es funktioniert",
  "settings": [
    { "type": "text", "id": "step1_title", "label": "Schritt 1 – Titel", "default": "Produkt wählen" },
    { "type": "textarea", "id": "step1_desc", "label": "Schritt 1 – Text", "default": "Stöbere durch unser Sortiment – von kühlem Bier bis Energy Drinks und Snacks." },
    { "type": "text", "id": "step2_title", "label": "Schritt 2 – Titel", "default": "Bestellen" },
    { "type": "textarea", "id": "step2_desc", "label": "Schritt 2 – Text", "default": "Leg alles in den Warenkorb und schließe deine Bestellung in wenigen Sekunden ab." },
    { "type": "text", "id": "step3_title", "label": "Schritt 3 – Titel", "default": "In 25 Min geliefert" },
    { "type": "textarea", "id": "step3_desc", "label": "Schritt 3 – Text", "default": "Unser Fahrer bringt deine Bestellung frisch & gekühlt direkt vor deine Haustür." }
  ],
  "presets": [{ "name": "Wie es funktioniert" }]
}
{% endschema %}
