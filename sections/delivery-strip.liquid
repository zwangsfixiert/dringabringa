{% comment %} sections/delivery-strip.liquid {% endcomment %}

<div class="delivery-strip">
  <div class="container">
    <div class="dl-item">
      <div class="dl-icon">🚀</div>
      <div class="dl-text">
        <strong>Expresslieferung</strong>
        <span>In nur 25 Minuten bei dir</span>
      </div>
    </div>
    <div class="dl-item">
      <div class="dl-icon">🌙</div>
      <div class="dl-text">
        <strong>21:00–09:00</strong>
        <span>Täglich für dich da</span>
      </div>
    </div>
    <div class="dl-item">
      <div class="dl-icon">🆓</div>
      <div class="dl-text">
        <strong>Gratis Lieferung</strong>
        <span>Ab 20 € Bestellwert</span>
      </div>
    </div>
    <div class="dl-item">
      <div class="dl-icon">❄️</div>
      <div class="dl-text">
        <strong>Gekühlt geliefert</strong>
        <span>Immer frisch & kalt</span>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lieferstreifen",
  "presets": [{ "name": "Lieferstreifen" }]
}
{% endschema %}
