{% comment %} templates/collection.liquid {% endcomment %}

{%- paginate collection.products by 24 -%}
<div class="container">
  <div class="collection-header">
    <div class="section-eyebrow">🦉 DringaBringa Shop</div>
    <div class="section-title">{{ collection.title }}</div>
    {% if collection.description != blank %}
      <p class="collection-desc">{{ collection.description }}</p>
    {% endif %}
  </div>

  {% comment %} Category filter pills {% endcomment %}
  <div class="cat-filters" role="navigation" aria-label="Kategorien">
    <a href="/collections/all" class="cat-pill {% if collection.handle == 'all' %}active{% endif %}">🛒 Alle</a>
    <a href="/collections/alkoholische-getranke" class="cat-pill {% if collection.handle == 'alkoholische-getranke' %}active{% endif %}">🍺 Alkoholische Getränke</a>
    <a href="/collections/softdrinks" class="cat-pill {% if collection.handle == 'softdrinks' %}active{% endif %}">🥤 Softdrinks</a>
    <a href="/collections/energy" class="cat-pill {% if collection.handle == 'energy' %}active{% endif %}">⚡ Energy</a>
    <a href="/collections/wasser" class="cat-pill {% if collection.handle == 'wasser' %}active{% endif %}">💧 Wasser</a>
    <a href="/collections/snacks" class="cat-pill {% if collection.handle == 'snacks' %}active{% endif %}">🍫 Snacks</a>
    <a href="/collections/sonstiges" class="cat-pill {% if collection.handle == 'sonstiges' %}active{% endif %}">🛍️ Sonstiges</a>
  </div>

  {% if collection.products_count == 0 %}
    <p class="collection-empty">Noch keine Produkte in dieser Kategorie.</p>
  {% else %}
    <div class="product-grid">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% endif %}

  {% if paginate.pages > 1 %}
    <div class="pagination">
      {{ paginate | default_pagination }}
    </div>
  {% endif %}
</div>
{%- endpaginate -%}
