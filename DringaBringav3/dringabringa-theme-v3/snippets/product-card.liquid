{% comment %} snippets/product-card.liquid – DringaBringa v3 {% endcomment %}

{% assign emoji = product.metafields.custom.emoji | default: '🍺' %}

{% if product.tags contains 'hot' %}
  {% assign badge = 'hot' %}
  {% assign badge_text = 'Hot' %}
{% elsif product.tags contains 'new' %}
  {% assign badge = 'new' %}
  {% assign badge_text = 'Neu' %}
{% elsif product.tags contains 'sale' %}
  {% assign badge = 'sale' %}
  {% assign badge_text = 'Angebot' %}
{% endif %}

{% comment %} Check if item is already in cart {% endcomment %}
{% assign cart_qty = 0 %}
{% for item in cart.items %}
  {% if item.product_id == product.id %}
    {% assign cart_qty = item.quantity %}
  {% endif %}
{% endfor %}

<div class="product-card{% if cart_qty > 0 %} in-cart{% endif %}" data-product-id="{{ product.id }}">

  <a href="{{ product.url }}" class="product-img-link" aria-label="{{ product.title }} – Details ansehen" tabindex="-1">
    <div class="product-img-wrap">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 400 }}"
          srcset="
            {{ product.featured_image | image_url: width: 200 }} 200w,
            {{ product.featured_image | image_url: width: 400 }} 400w,
            {{ product.featured_image | image_url: width: 600 }} 600w
          "
          sizes="(max-width: 640px) calc(50vw - 32px), (max-width: 1200px) calc(33vw - 32px), 260px"
          width="400" height="300"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          loading="lazy" decoding="async"
        >
      {% else %}
        <span role="img" aria-label="{{ product.title }}">{{ emoji }}</span>
      {% endif %}

      {% if badge %}
        <span class="product-badge badge-{{ badge }}">{{ badge_text }}</span>
      {% endif %}

      {% if cart_qty > 0 %}
        <div class="cart-qty-badge" aria-label="{{ cart_qty }} im Warenkorb">{{ cart_qty }}</div>
      {% endif %}
    </div>
  </a>

  <div class="product-body">
    {% if product.vendor != blank %}
      <div class="product-vendor">{{ product.vendor }}</div>
    {% endif %}
    <a href="{{ product.url }}" class="product-title">{{ product.title }}</a>
    <div class="product-desc">
      {% if product.metafields.custom.subtitle != blank %}
        {{ product.metafields.custom.subtitle }}
      {% else %}
        {{ product.description | strip_html | truncate: 60 }}
      {% endif %}
    </div>

    <div class="product-footer">
      <div class="product-price-wrap">
        <span class="product-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="product-price-compare">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      <div class="atc-controls" role="group" aria-label="{{ product.title }} – Menge">
        {% if cart_qty > 0 %}
          <button class="atc-btn atc-minus"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            data-product-title="{{ product.title | escape }}"
            aria-label="{{ product.title }} aus Warenkorb entfernen"
            onclick="removeFromCart(this)">−</button>
        {% endif %}
        <button class="atc-btn atc-plus"
          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
          data-product-title="{{ product.title | escape }}"
          aria-label="{{ product.title }} in den Warenkorb"
          onclick="addToCart(this)">+</button>
      </div>
    </div>
  </div>
</div>
