{% comment %} sections/featured-collection.liquid – DringaBringa v3 {% endcomment %}

{% assign collection = collections[section.settings.collection] %}

{% if collection != blank %}
<section class="section-pad">
  <div class="container">

    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:16px;">
      <div>
        <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
        <div class="section-title">{{ section.settings.title }}</div>
      </div>
      <a href="{{ collection.url }}" style="font-family:'Barlow Condensed',sans-serif; font-size:0.85rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--mint); border-bottom:1px solid rgba(0,229,176,0.3); padding-bottom:2px; white-space:nowrap;">Alle ansehen →</a>
    </div>

    {%- comment -%} Category filter pills – rendered by JS if multiple tags present {%- endcomment -%}
    <div class="cat-filters" id="catFilters" aria-label="Kategorie-Filter">
      <button class="cat-pill active" data-cat="all" onclick="filterProducts(this, 'all')">🛍️ Alles</button>
      <button class="cat-pill" data-cat="bier" onclick="filterProducts(this, 'bier')">🍺 Bier</button>
      <button class="cat-pill" data-cat="energy" onclick="filterProducts(this, 'energy')">⚡ Energy</button>
      <button class="cat-pill" data-cat="softdrinks" onclick="filterProducts(this, 'softdrinks')">🥤 Softdrinks</button>
      <button class="cat-pill" data-cat="wasser" onclick="filterProducts(this, 'wasser')">💧 Wasser</button>
      <button class="cat-pill" data-cat="snacks" onclick="filterProducts(this, 'snacks')">🍫 Snacks</button>
    </div>

    <div class="product-grid" id="productGrid">
      {% for product in collection.products limit: section.settings.products_to_show %}
        <div data-tags="{{ product.tags | join: ',' | downcase }}" class="product-grid-item">
          {% render 'product-card', product: product %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<script>
function filterProducts(btn, cat) {
  // Update active pill
  document.querySelectorAll('#catFilters .cat-pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');

  // Show/hide products
  document.querySelectorAll('#productGrid .product-grid-item').forEach(item => {
    if (cat === 'all') {
      item.style.display = '';
    } else {
      const tags = (item.dataset.tags || '').split(',');
      item.style.display = tags.some(t => t.trim() === cat) ? '' : 'none';
    }
  });
}
</script>
{% endif %}

{% schema %}
{
  "name": "Produkt-Kollektion",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "🔥 Beliebt diese Nacht" },
    { "type": "text", "id": "title", "label": "Überschrift", "default": "Top Produkte" },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    { "type": "range", "id": "products_to_show", "label": "Anzahl Produkte", "min": 2, "max": 24, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "Produkt-Kollektion" }]
}
{% endschema %}
