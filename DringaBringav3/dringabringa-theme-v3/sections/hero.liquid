{% comment %} sections/hero.liquid – DringaBringa v3 {% endcomment %}

{% assign phone_raw = section.settings.phone_number | default: '+4365077456​16' | remove: ' ' | remove: '/' | remove: '(' | remove: ')' %}

<section class="hero">
  <div class="hero-glow-l"></div>
  <div class="hero-glow-r"></div>
  <div class="hero-glow-b"></div>

  <div class="hero-inner">

    {%- comment -%} Live-Status Badge {%- endcomment -%}
    <div class="hero-badge" id="heroBadge" aria-live="polite">
      <div class="live-dot"></div>
      <span class="hero-badge-text">Lieferung in 25 Min · 21:00–09:00</span>
    </div>

    {%- comment -%} Logo / Mascot {%- endcomment -%}
    {% if section.settings.logo_image %}
      <div class="hero-logo-wrap">
        <img
          src="{{ section.settings.logo_image | image_url: width: 400 }}"
          srcset="
            {{ section.settings.logo_image | image_url: width: 200 }} 200w,
            {{ section.settings.logo_image | image_url: width: 400 }} 400w
          "
          sizes="(max-width: 640px) 200px, 320px"
          alt="DringaBringa Maskottchen"
          width="320" height="320"
          loading="eager" fetchpriority="high"
        />
      </div>
    {% endif %}

    <h1>
      <span class="t-fire">DRINGA</span>
      <span class="t-ice">BRINGA</span>
    </h1>

    <p class="hero-sub">{{ section.settings.hero_sub | default: 'Getränke &amp; Snacks – direkt zu Dir nach Hause.' }}<br>Täglich <strong>21:00–09:00 Uhr</strong> · Wels</p>

    <div class="hero-cta">
      <a href="/collections/all" class="btn-fire">🍺 Jetzt bestellen</a>
      <a href="tel:{{ phone_raw }}" class="btn-outline">📞 Anrufen</a>
    </div>

    <div class="hero-stats" aria-label="Unsere Kennzahlen">
      <div>
        <div class="stat-num">25 Min</div>
        <div class="stat-label">Lieferzeit</div>
      </div>
      <div>
        <div class="stat-num">{{ section.settings.product_count | default: '50' }}+</div>
        <div class="stat-label">Produkte</div>
      </div>
      <div>
        <div class="stat-num">21–09</div>
        <div class="stat-label">Täglich</div>
      </div>
      <div>
        <div class="stat-num">4.9★</div>
        <div class="stat-label">Bewertung</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "logo_image", "label": "Maskottchen / Logo Bild" },
    { "type": "text", "id": "phone_number", "label": "Telefonnummer (Anzeige)", "default": "+43 650 / 77 45 616" },
    { "type": "text", "id": "hero_sub", "label": "Untertitel", "default": "Getränke & Snacks – direkt zu Dir nach Hause." },
    { "type": "text", "id": "product_count", "label": "Produktanzahl (Anzeige)", "default": "50" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
